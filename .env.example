# =================================================================
# Mart Artwork System - 环境变量示例
# =================================================================

# 1. 服务运行端口 (本地默认 3000, Zeabur 会自动识别)
PORT=3000

# 2. MySQL 数据库连接配置
# -----------------------------------------------------------------
# [本地开发]: 通常使用 localhost 或 127.0.0.1
# [Zeabur 部署]: 
# - 如果是同一项目内的 MySQL 服务，使用内网地址 (例如: mysql.zeabur.internal)
# - 如果是外部数据库，填写对应的公网地址
# -----------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mart_artwork
MYSQL_PORT=3306

# 注意: 不要将真实的密码提交到 GitHub 仓储中
